# Backend API base URL (must end with /api).
# Production (recommended when testing bookings against the live backend):
REACT_APP_API_URL=https://ryde-backend-production.up.railway.app/api
#
# Local backend: comment out REACT_APP_API_URL above, run ryde-backend on :3000,
# then start the web app on another port so it does not clash:
#   set PORT=3001 && npm start
# CRA will proxy /api -> http://localhost:3000 via src/setupProxy.js

# Google Maps (get key at https://console.cloud.google.com/apis/credentials)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_keyAIzaSyC0hBNKoBnYhqmle-QoJwk4_GObUQG

# IremboPay widget (public key pk_… from dashboard; must match IREMBOPAY_ENVIRONMENT — use sandbox key with sandbox inline script)
REACT_APP_IPAY_PUBLIC_KEY=pk_sandbox_your_public_key
